#!/bin/bash
# hello-info - System information command
# Part of hello-world package

VERSION="1.0.0"
LIB_PATH="/usr/share/hello-world/hello-lib.sh"

# Source library if exists
[ -f "$LIB_PATH" ] && source "$LIB_PATH"

case "${1:-}" in
    -h|--help)
        echo "Usage: hello-info [OPTIONS]"
        echo "Options:"
        echo "  -h, --help      Show help"
        echo "  -v, --version   Show version"
        echo "  -s, --short     Short output"
        ;;
    -v|--version)
        echo "hello-info version $VERSION"
        ;;
    -s|--short)
        echo "$(uname -n) | $(uname -r) | $(uname -m)"
        ;;
    *)
        print_header "System Information"
        echo "Hostname: $(uname -n)"
        echo "Kernel:   $(uname -r)"
        echo "Arch:     $(uname -m)"
        echo "User:     $(whoami)"
        echo "Date:     $(date)"
        ;;
esac
